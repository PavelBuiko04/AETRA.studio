{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./js",
    "rootDir": "./ts",
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmitOnError": true
  },
  "include": ["ts/**/*"]
}
